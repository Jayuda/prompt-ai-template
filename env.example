# Salin file ini ke .env dan sesuaikan nilainya.
# cp .env.example .env

# ── Prompt Profile ────────────────────────────────────────────
# Pilih folder prompt yang ingin dipakai.
# Setiap subfolder di prompts/ berisi: system.md, rules.md, tools.md, endpoints.json
#
# Cara menambah profil baru:
#   1. Buat folder baru, misal: prompts/project-a/
#   2. Salin isi prompts/default/ ke dalamnya
#   3. Edit file sesuai kebutuhan
#   4. Set PROMPTS_DIR=./prompts/project-a di .env
# ──────────────────────────────────────────────────────────────
PROMPTS_DIR=./prompts/default

# ── LLM ───────────────────────────────────────────────────────
LLM_API=http://localhost:8080/v1/chat/completions
LLM_MODEL=qwen3-8b
LLM_TOKEN=

# ── Server ────────────────────────────────────────────────────
SERVER_PORT=8000

# ── LLM Timeouts & Retry ──────────────────────────────────────
RAG_CONNECT_TIMEOUT=10
RAG_READ_TIMEOUT=600
RAG_RETRY_TOTAL=2
RAG_RETRY_BACKOFF=1

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=datatags_agent
